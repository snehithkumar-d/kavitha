{{!< default}}

<div class="container">

    <header class="collection-header">
        <div class="page-breadcrumb">~ /projects</div>
        <h1 class="collection-title">{{@custom.projects_section_title}}</h1>
    </header>

    {{#if posts}}
        <div class="project-grid project-grid-collection">
            {{#foreach posts}}
                {{> "project-card"}}
            {{/foreach}}
        </div>

        {{> "pagination"}}
    {{else}}
        <p class="collection-empty">No projects published yet. Check back soon.</p>
    {{/if}}

</div>
