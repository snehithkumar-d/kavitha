<!DOCTYPE html>
<html lang="{{@site.locale}}" data-color-scheme-default="{{#match @custom.color_scheme_default "Light"}}light{{else match @custom.color_scheme_default "Dark"}}dark{{else}}auto{{/match}}" data-accent-preset="{{#match @custom.accent_preset "Terracotta"}}terracotta{{else}}teal{{/match}}">
<head>

    {{!-- Document Settings --}}
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    {{!-- Page Meta --}}
    <title>{{meta_title}}</title>
    <meta name="HandheldFriendly" content="True" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {{!-- Fonts — Google Fonts CSS API.
         Self-hosted woff2 was attempted in v0.1.x but fetch-fonts.sh produced
         tiny static subsets (~22KB) instead of true variable fonts, so
         font-variation-settings did nothing. v0.2 plan: ship proper TTF→woff2
         converted variable fonts. For now, Google Fonts gets us the right look. --}}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,400;1,9..144,500;1,9..144,600&family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap">

    {{!-- Styles --}}
    <link rel="stylesheet" type="text/css" href="{{asset "built/screen.css"}}" />

    {{!-- Custom-setting-driven CSS variables.
         color values from config.custom can't go in inline style="" (sanitized in some contexts) so we inject a <style> block instead. See loophole #17.
         Ghost admin → Design → Customize → Fonts always wins via --gh-font-body / --gh-font-heading set in screen.css. --}}
    <style>
        :root {
            --kavitha-body-font: {{#match @custom.body_font "Sans-serif"}}var(--gh-font-body, var(--font-sans)){{else match @custom.body_font "Mono"}}var(--gh-font-body, var(--font-mono)){{else}}var(--gh-font-body, var(--font-serif)){{/match}};
            --kavitha-heading-font: var(--gh-font-heading, var(--kavitha-body-font));
        }
    </style>

    {{!-- Theme bootstrap: hydrate user's theme + accent-contrast preference BEFORE first paint to prevent FOUC.
         This is the ONE inline script we ship; all other JS is bundled in source.js per loophole #11. --}}
    <script>
        (function () {
            var doc = document.documentElement;
            try {
                var defaultPref = doc.getAttribute('data-color-scheme-default') || 'auto';
                var stored = localStorage.getItem('kavitha-theme');
                var resolved = stored || (defaultPref === 'auto' ? '' : defaultPref);
                if (resolved === 'light' || resolved === 'dark') {
                    doc.setAttribute('data-theme', resolved);
                }

                {{!-- Accent preset: localStorage (visitor) > admin theme setting > Ghost brand color. --}}
                var accentMap = { teal: '#1e6b6b', terracotta: '#c15f3c' };
                var storedAccent = localStorage.getItem('kavitha-accent');
                var adminAccent = doc.getAttribute('data-accent-preset');
                var resolvedPreset = (storedAccent && accentMap[storedAccent]) ? storedAccent
                                   : (adminAccent && accentMap[adminAccent]) ? adminAccent
                                   : null;
                var accent;
                if (resolvedPreset) {
                    accent = accentMap[resolvedPreset];
                    doc.style.setProperty('--ghost-accent-color', accent);
                    doc.style.setProperty('--accent', accent);
                } else {
                    accent = getComputedStyle(doc).getPropertyValue('--ghost-accent-color').trim() || '{{@site.accent_color}}';
                }

                {{!-- Accent text color: derive from accent luminance (auto-only) --}}
                if (accent && accent.charAt(0) === '#') {
                    var hex = accent.length === 4
                        ? '#' + accent[1] + accent[1] + accent[2] + accent[2] + accent[3] + accent[3]
                        : accent;
                    var r = parseInt(hex.substr(1, 2), 16);
                    var g = parseInt(hex.substr(3, 2), 16);
                    var b = parseInt(hex.substr(5, 2), 16);
                    var lum = (0.2126 * r + 0.7152 * g + 0.0722 * b) / 255;
                    doc.style.setProperty('--accent-text', lum > 0.55 ? '#0a0b0d' : '#ffffff');
                }
            } catch (e) { /* localStorage may be unavailable; fall through to defaults */ }
        })();
    </script>

    {{!-- Prism.js syntax highlighting — only loaded on post / page templates.
         Autoloader fetches grammars on-demand from the same CDN, so we ship
         core (~6 KB) + only the languages actually used in the post body.
         Mermaid is loaded lazily by source.js when a .language-mermaid block
         is detected (graceful: pages without diagrams pay zero KB). --}}
    {{#is "post, page"}}
        <script defer src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/components/prism-core.min.js"></script>
        <script defer src="https://cdn.jsdelivr.net/npm/prismjs@1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    {{/is}}

    {{ghost_head}}

</head>
<body class="{{body_class}}">

    <a class="skip-link" href="#site-main">Skip to content</a>

    {{!-- Reading scroll-progress bar — only animates on post templates via CSS. --}}
    <div class="scroll-progress" aria-hidden="true"><div class="scroll-progress-bar"></div></div>

    <div class="site-wrap">

        {{> "site-header"}}

        <main id="site-main" class="site-main">
            {{{body}}}
        </main>

        {{> "site-footer"}}

    </div>

    {{!-- External JS bundle (theme toggle, mobile nav, etc.) --}}
    <script src="{{asset "built/source.js"}}"></script>

    {{ghost_foot}}

</body>
</html>
