{{!< default}}

<div class="container container-narrow error-page">

    <span class="error-eyebrow">{{statusCode}}</span>
    <h1 class="error-title">
        {{#match statusCode "404"}}Page not found.{{else}}{{message}}{{/match}}
    </h1>
    <p class="error-body">
        {{#match statusCode "404"}}
            That URL doesn't exist on this site. Try the homepage, the writing, or use search.
        {{else}}
            Something went sideways. Try refreshing, or head back to the homepage.
        {{/match}}
    </p>

    <nav class="error-nav">
        <a class="error-link" href="{{@site.url}}">Home</a>
        <a class="error-link" href="/writing/">Writing</a>
        <a class="error-link" href="/projects/">Projects</a>
        <button class="error-link" type="button" data-ghost-search>Search</button>
    </nav>

</div>
