{{!< default}}

<div class="container">

    <header class="site-hero">
        <div class="site-hero-prompt">~ /home/{{#if @custom.terminal_handle}}{{@custom.terminal_handle}}{{else}}{{@site.title}}{{/if}}</div>
        <h1 class="site-hero-title">{{@site.title}}</h1>
        {{#if @site.description}}
            <p class="site-hero-bio">{{@site.description}}</p>
        {{/if}}
    </header>

    {{#get "posts" limit="5" filter="tag:-hash-project" order="published_at desc" as |home_posts|}}
        {{#if home_posts}}
            <div class="section-band">
                <h2 class="section-band-label"><span class="band-prompt">$</span> {{@custom.blog_section_title}}</h2>
                <a class="section-band-more" href="/blog/">All writing →</a>
            </div>

            <ul class="terminal-list">
                {{#foreach home_posts}}
                    <li class="terminal-list-row">
                        <time class="terminal-list-date" datetime="{{date format="YYYY-MM-DD"}}">{{date format="YYYY-MM-DD"}}</time>
                        <div class="terminal-list-body">
                            <h3 class="terminal-list-title"><a href="{{url}}">{{title}}</a></h3>
                            <p class="terminal-list-excerpt">{{excerpt words="22"}}</p>
                        </div>
                    </li>
                {{/foreach}}
            </ul>
        {{else}}
            <section class="home-empty">
                {{#if @site.description}}<p class="home-empty-deck">{{@site.description}}</p>{{/if}}
                <p class="home-empty-cta">No posts yet. Sign in to your Ghost admin and publish your first one.</p>
            </section>
        {{/if}}
    {{/get}}

    {{#get "posts" limit="2" filter="tag:hash-project" order="published_at desc" as |projects|}}
        {{#if projects}}
            <div class="section-band">
                <h2 class="section-band-label"><span class="band-prompt">$</span> {{@custom.projects_section_title}}</h2>
                <a class="section-band-more" href="/projects/">All work →</a>
            </div>

            <div class="project-grid project-grid-home">
                {{#foreach projects}}
                    {{> "project-card"}}
                {{/foreach}}
            </div>
        {{/if}}
    {{/get}}

    {{> "members-cta"}}

</div>
