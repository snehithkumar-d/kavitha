{{!< default}}

<div class="container container-narrow">

    <header class="collection-header">
        <div class="page-breadcrumb">~ /writing</div>
        <h1 class="collection-title">{{@custom.blog_section_title}}</h1>
        {{#if @custom.blog_section_subtitle}}
            <p class="collection-subtitle">{{@custom.blog_section_subtitle}}</p>
        {{/if}}
    </header>

    <div class="post-feed">
        {{#foreach posts}}
            {{> "post-card"}}
        {{/foreach}}
    </div>

    {{> "pagination"}}

</div>
