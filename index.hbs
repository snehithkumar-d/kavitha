{{!< default}}

<div class="container container-narrow">

    <header class="collection-header">
        <div class="page-breadcrumb">~ /writing</div>
        <h1 class="collection-title">{{@custom.blog_section_title}}</h1>
    </header>

    {{#if posts}}
        <div class="post-feed">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>

        {{> "pagination"}}
    {{else}}
        <p class="collection-empty">Nothing published here yet. Check back soon.</p>
    {{/if}}

</div>
