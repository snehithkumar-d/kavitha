{{!-- Social share buttons — opens X / LinkedIn share dialogs in a new window;
     copy-link uses navigator.clipboard via source.js. --}}

<div class="share-buttons" role="group" aria-label="Share this post">
    <span class="share-buttons-label">Share</span>
    <a class="share-button" href="https://twitter.com/intent/tweet?url={{url absolute="true"}}&amp;text={{encode title}}" target="_blank" rel="noopener noreferrer" aria-label="Share on X / Twitter">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M17.53 3h3.31l-7.23 8.27L22 21h-6.58l-5.16-6.74L4.32 21H1l7.74-8.85L0.5 3h6.75l4.66 6.16L17.53 3zm-1.16 16h1.83L7.7 5H5.74l10.63 14z"/></svg>
        <span class="sr-only">X</span>
    </a>
    <a class="share-button" href="https://www.linkedin.com/sharing/share-offsite/?url={{url absolute="true"}}" target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 18V10H5.67v8h2.67zM7 8.84a1.55 1.55 0 1 0 0-3.09 1.55 1.55 0 0 0 0 3.09zM18.34 18v-4.39c0-2.42-1.3-3.55-3.03-3.55-1.39 0-2.02.77-2.37 1.31V10H10.27c.04.76 0 8 0 8h2.67v-4.47c0-.24.02-.48.09-.65.18-.48.62-.97 1.36-.97.96 0 1.34.73 1.34 1.8V18h2.61z"/></svg>
        <span class="sr-only">LinkedIn</span>
    </a>
    <button type="button" class="share-button" data-share-copy data-url="{{url absolute="true"}}" aria-label="Copy link to this post">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.07 0l3-3a5 5 0 0 0-7.07-7.07l-1.5 1.5"/><path d="M14 11a5 5 0 0 0-7.07 0l-3 3a5 5 0 0 0 7.07 7.07l1.5-1.5"/></svg>
        <span class="share-button-status" data-share-status>Copy link</span>
    </button>
</div>
