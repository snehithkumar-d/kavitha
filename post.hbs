{{!< default}}

{{#post}}

<article class="post {{post_class}}" itemscope itemtype="http://schema.org/Article">

    <header class="post-header">
        <div class="container container-narrow">
            <div class="page-breadcrumb">~ /writing</div>

            <h1 class="post-title" itemprop="headline">{{title}}</h1>

            {{#if custom_excerpt}}
                <p class="post-deck">{{custom_excerpt}}</p>
            {{/if}}

            {{> "byline"}}
        </div>
    </header>

    {{#if feature_image}}
        {{#if @custom.show_feature_image_on_post}}
            <figure class="post-feature-image post-feature-image-{{#match @custom.post_image_style "Full-width"}}full{{else match @custom.post_image_style "Inline"}}inline{{else}}wide{{/match}}">
                <img src="{{img_url feature_image size="l"}}"
                     srcset="{{img_url feature_image size="m"}} 720w,
                             {{img_url feature_image size="l"}} 960w,
                             {{img_url feature_image size="xl"}} 1200w,
                             {{img_url feature_image size="xxl"}} 2000w"
                     sizes="(min-width: 1100px) 1100px, 100vw"
                     alt="{{feature_image_alt}}"
                     loading="eager"
                     decoding="async"
                     itemprop="image" />
                {{#if feature_image_caption}}
                    <figcaption>{{{feature_image_caption}}}</figcaption>
                {{/if}}
            </figure>
        {{/if}}
    {{/if}}

    <div class="container container-narrow">
        <div class="post-body" itemprop="articleBody">
            {{content}}
        </div>

        {{#if tags.[1]}}
            <div class="post-tags">
                {{#foreach tags}}
                    {{#unless visibility}}{{else match visibility "public"}}
                        {{#unless @first}}
                            <a class="post-tag-chip" href="{{url}}">{{name}}</a>
                        {{/unless}}
                    {{/unless}}
                {{/foreach}}
            </div>
        {{/if}}
    </div>

</article>

<div class="container container-narrow">

    {{> "share-buttons"}}

    {{#unless access}}
        {{> "members-cta"}}
    {{/unless}}

    {{> "related-posts"}}

    {{#if comments_enabled}}
        <section class="post-comments" id="comments">
            <h3 class="post-comments-title">Comments</h3>
            {{comments title=""}}
        </section>
    {{/if}}

    {{!-- Prev/next within the post's primary collection. See loophole #22. --}}
    <nav class="post-prev-next" aria-label="Adjacent posts">
        {{#prev_post}}
            <a class="post-prev" href="{{url}}">
                <span class="label">← Previous</span>
                <span class="title">{{title}}</span>
            </a>
        {{/prev_post}}
        {{#next_post}}
            <a class="post-next" href="{{url}}">
                <span class="label">Next →</span>
                <span class="title">{{title}}</span>
            </a>
        {{/next_post}}
    </nav>
</div>

{{/post}}
