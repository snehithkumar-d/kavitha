{{!< default}}

<div class="container container-narrow">

    {{#tag}}
        <header class="collection-header">
            <div class="page-breadcrumb">~ /tag/{{slug}}</div>
            <h1 class="collection-title">#{{name}}</h1>
            {{#if description}}
                <p class="collection-subtitle">{{description}}</p>
            {{/if}}
            <p class="collection-count">{{plural ../pagination.total empty='No posts' singular='1 post' plural='% posts'}}</p>
        </header>
    {{/tag}}

    {{#if posts}}
        <div class="post-feed">
            {{#foreach posts}}
                {{> "post-card"}}
            {{/foreach}}
        </div>

        {{> "pagination"}}
    {{else}}
        <p class="collection-empty">No posts tagged here yet.</p>
    {{/if}}

</div>
